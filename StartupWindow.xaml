<Window x:Class="WpfResourceGantt.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:WpfResourceGantt.ProjectManagement.Converters"
        mc:Ignorable="d"
        Title="Mission Resource Command - Login" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ProjectManagement/UI/Styles/CoreStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource TacticalRibbonBackgroundBrush}" CornerRadius="12" BorderBrush="{StaticResource TacticalBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: Branding -->
            <Border Grid.Column="0" Background="{StaticResource TacticalBackgroundBrush}" CornerRadius="12,0,0,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Placeholder Logo -->
                    <Border Width="80" Height="80" Background="{StaticResource TacticalPrimaryBrush}" CornerRadius="40" Margin="0,0,0,20">
                        <Path Data="M12 2L2 7l10 5 10-5-10-5zm0 9l2.5-1.25L12 16l-2.5-6.25L12 11zm0 2.5l-5-2.5-5 2.5L12 22l10-8.5-5-2.5-5 2.5z" 
                              Fill="Black" Stretch="Uniform" Margin="20"/>
                    </Border>
                    
                    <TextBlock Text="AM PROJECT" 
                               Foreground="{StaticResource TacticalTextPrimaryBrush}" 
                               FontSize="24" FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center"/>
                    <TextBlock Text="SUITE" 
                               Foreground="{StaticResource TacticalPrimaryBrush}" 
                               FontSize="24" FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center"
                               Margin="0,-5,0,0"/>

                    <TextBlock Text="v1.0 - AM Enterprise" 
                               Foreground="{StaticResource TacticalTextMutedBrush}" 
                               FontSize="12" 
                               HorizontalAlignment="Center" 
                               Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- RIGHT SIDE: Login Form -->
            <Grid Grid.Column="1" Margin="40">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Welcome Back" 
                               Foreground="{StaticResource TacticalTextPrimaryBrush}" 
                               FontSize="28" FontWeight="SemiBold" 
                               Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Select your profile to continue" 
                               Foreground="{StaticResource TacticalTextMutedBrush}" 
                               FontSize="14" 
                               Margin="0,0,0,40"/>

                    <!-- User Selection -->
                    <TextBlock Text="USER PROFILE" 
                               Foreground="{StaticResource TacticalTextMutedBrush}" 
                               FontSize="11" FontWeight="Bold" 
                               Margin="0,0,0,8"/>
                    
                    <ComboBox ItemsSource="{Binding Users}" 
                               SelectedItem="{Binding SelectedUser}"
                               DisplayMemberPath="Name"
                               Padding="10"
                               Height="45"
                               FontSize="14"
                               Margin="0,0,0,30">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="10"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <!-- Login Button -->
                    <Button Command="{Binding LoginCommand}" 
                            Content="ACCESS DASHBOARD" 
                            Height="50"
                            Style="{StaticResource TacticalPrimaryButtonStyle}"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand"/>

                    <!-- Loading Indicator -->
                    <ProgressBar IsIndeterminate="True" 
                                 Height="2" 
                                 Margin="0,20,0,0"
                                 Background="Transparent"
                                 Foreground="{StaticResource TacticalPrimaryBrush}"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                
                <!-- Close Button (Top Right) -->
                <Button Content="✕" 
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="30" Height="30"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TacticalTextMutedBrush}"
                        Click="CloseButton_Click"
                        Margin="0,-20,-20,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
