<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.Simulation.SimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:WpfResourceGantt.ProjectManagement.Features.Simulation"
             xmlns:gantt="clr-namespace:WpfResourceGantt.ProjectManagement.Features.Gantt"
             xmlns:models="clr-namespace:WpfResourceGantt.ProjectManagement.Models"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200" Background="{StaticResource SurfaceBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Merging the core application styles and icons -->
                <ResourceDictionary Source="../../UI/Styles/Icons.xaml"/>
                <ResourceDictionary Source="../../UI/Styles/CoreStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Header -->
            <RowDefinition Height="350"/>
            <!-- 1: Master/Detail Workspace -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Impact Bar -->
            <RowDefinition Height="*"/>
            <!-- 3: Sandbox Gantt -->
        </Grid.RowDefinitions>

        <!-- SECTION 0: HEADER CONTROLS -->
        <Border Grid.Row="0" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TEMPORAL SANDBOX" Foreground="{StaticResource TacticalGoldBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,20,0"/>

                    <TextBlock Text="Simulated Status Date:" Foreground="{StaticResource TacticalTextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding SimulatedDate}" 
                            Width="150" 
                            Margin="0,0,20,0"
                            Style="{StaticResource TacticalDatePickerStyle}"/>
                    <Button Content="Recalculate Reality" Command="{Binding RecalculateCommand}" Style="{StaticResource TacticalPrimaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="Reset Sandbox" Command="{Binding ResetSimulationCommand}" Style="{StaticResource TacticalSecondaryButtonStyle}"/>
                </StackPanel>
                </Grid>
        </Border>

        <!-- SECTION 1: WORKSPACE -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Master Tree -->
            <Border Grid.Column="0" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="10">
                <TreeView x:Name="SandboxTreeView" ItemsSource="{Binding SimulatedSystems}" 
                          Background="Transparent" BorderThickness="0" 
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type models:SystemItem}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource TacticalTextPrimaryBrush}"/>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:WorkBreakdownItem}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <!-- RIGHT: Interactive Manipulator -->
            <Border Grid.Column="2" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="15">
                <Grid IsEnabled="{Binding IsItemSelected}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title/Toggle -->
                        <RowDefinition Height="Auto"/>
                        <!-- Summary Warning -->
                        <RowDefinition Height="*"/>
                        <!-- Graph Area -->
                        <RowDefinition Height="Auto"/>
                        <!-- Flatline Button -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="INTERACTIVE MANIPULATOR" FontSize="12" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                            <TextBlock Text="{Binding SelectedItem.Name, TargetNullValue='Select an item'}" 
                                       FontSize="18" FontWeight="Bold" Foreground="{StaticResource TacticalGoldBrush}"/>
                        </StackPanel>

                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Content="Toggle Mode (Progress / Actuals)" 
                                Command="{Binding ToggleEditModeCommand}" 
                                Style="{StaticResource TacticalSecondaryButtonStyle}"/>
                    </Grid>

                    <!-- Row 1: Summary Warning -->
                    <Border Grid.Row="1" Background="#33FF9900" Padding="10" CornerRadius="4" Margin="0,0,0,10"
                            Visibility="{Binding SelectedItem.IsSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Summary Item: Graph is read-only (Calculated from children)." 
                                   Foreground="#FFFF9900" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Row 2: The Graph -->
                    <local:InteractiveManipulatorGraph Grid.Row="2" 
                                                       DataPoints="{Binding InteractiveDataPoints}" 
                                                       EditMode="{Binding CurrentEditMode}"
                                                       StatusDate="{Binding SimulatedDate}"
                                                       IsEnabled="{Binding SelectedItem.IsLeaf}"
                                                       MaxActualHours="200"
                                                       Margin="0,0,0,10"/>

                    <!-- Row 3: Actions -->
                    <Button Grid.Row="3" Content="Flatline Future (Drop last 3 weeks)" 
                            Command="{Binding FlatlineFutureCommand}" 
                            Style="{StaticResource TacticalWarningButtonStyle}" 
                            Width="250" HorizontalAlignment="Left"
                            Visibility="{Binding SelectedItem.IsLeaf, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- SECTION 2: IMPACT METRICS BAR -->
        <Border Grid.Row="2" Background="{StaticResource TacticalDarkAccentBrush}" CornerRadius="6" Padding="15" Margin="0,10,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="LIVE SV" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding LiveTotalSv, StringFormat={}{0:C0}}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="SIMULATED SV" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding SimTotalSv, StringFormat={}{0:C0}}" Foreground="{StaticResource TacticalGoldBrush}" FontSize="24" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="FINANCIAL IMPACT" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding ImpactSv, StringFormat={}{0:C0}}" Foreground="#FF5555" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SECTION 3: SANDBOX GANTT -->
        <Border Grid.Row="3" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="5">
            <gantt:GanttView DataContext="{Binding SandboxGanttContext}" />
        </Border>
    </Grid>
</UserControl>
