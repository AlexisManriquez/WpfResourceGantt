<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.Simulation.SimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:WpfResourceGantt.ProjectManagement.Features.Simulation"
             xmlns:gantt="clr-namespace:WpfResourceGantt.ProjectManagement.Features.Gantt"
             xmlns:models="clr-namespace:WpfResourceGantt.ProjectManagement.Models"
             xmlns:converters="clr-namespace:WpfResourceGantt.ProjectManagement.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200" Background="{StaticResource SurfaceBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Merging the core application styles and icons -->
                <ResourceDictionary Source="../../UI/Styles/Icons.xaml"/>
                <ResourceDictionary Source="../../UI/Styles/CoreStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:EvmDeltaColorConverter x:Key="EvmDeltaColorConverter"/>
            
            <Style x:Key="MetricCardHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource TacticalTextMutedBrush}"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <Style x:Key="MetricValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style x:Key="MetricSimValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource TacticalGoldBrush}"/>
            </Style>

            <Style x:Key="MetricDeltaStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Header -->
            <RowDefinition Height="350"/>
            <!-- 1: Master/Detail Workspace -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Critical Path Alert (NEW) -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Impact Bar -->
            <RowDefinition Height="*"/>
            <!-- 4: Sandbox Gantt -->
        </Grid.RowDefinitions>

        <!-- SECTION 0: HEADER CONTROLS -->
        <Border Grid.Row="0" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Sandbox Controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TEMPORAL SANDBOX" Foreground="{StaticResource TacticalGoldBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,20,0"/>

                    <TextBlock Text="Simulated Status Date:" Foreground="{StaticResource TacticalTextMutedBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding SimulatedDate}" 
                            Width="150" 
                            Margin="0,0,20,0"
                            Style="{StaticResource TacticalDatePickerStyle}"/>
                    <Button Content="Recalculate Reality" Command="{Binding RecalculateCommand}" Style="{StaticResource TacticalPrimaryButtonStyle}" Margin="0,0,10,0"/>
                    <Button Content="Reset Sandbox" Command="{Binding ResetSimulationCommand}" Style="{StaticResource TacticalSecondaryButtonStyle}"/>
                </StackPanel>

                <!-- Right: Stress Test Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#22FFFFFF" CornerRadius="4" Padding="3" Margin="0,0,8,0">
                        <TextBlock Text="⚡" FontSize="14" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="STRESS TEST:" Foreground="{StaticResource TacticalTextMutedBrush}" FontWeight="SemiBold" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding StressTestScenarios}" 
                              SelectedItem="{Binding SelectedScenario}"
                              Width="260" Height="30" 
                              VerticalContentAlignment="Center" Padding="8,0"
                              ToolTip="{Binding SelectedScenario.Description}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,8,0" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="▶ Run Scenario" 
                            Command="{Binding ExecuteScenarioCommand}" 
                            Style="{StaticResource TacticalWarningButtonStyle}" 
                            Margin="10,0,0,0" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SECTION 1: WORKSPACE -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Master Tree -->
            <Border Grid.Column="0" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="10">
                <TreeView x:Name="SandboxTreeView" ItemsSource="{Binding SimulatedSystems}" 
                          Background="Transparent" BorderThickness="0" 
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type models:SystemItem}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource TacticalTextPrimaryBrush}"/>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:WorkBreakdownItem}" ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <!-- RIGHT: Interactive Manipulator -->
            <Border Grid.Column="2" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="15">
                <Grid IsEnabled="{Binding IsItemSelected}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title/Toggle -->
                        <RowDefinition Height="Auto"/>
                        <!-- Summary Warning -->
                        <RowDefinition Height="*"/>
                        <!-- Graph Area -->
                        <RowDefinition Height="Auto"/>
                        <!-- Flatline Button -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="INTERACTIVE MANIPULATOR" FontSize="12" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                            <TextBlock Text="{Binding SelectedItem.Name, TargetNullValue='Select an item'}" 
                                       FontSize="18" FontWeight="Bold" Foreground="{StaticResource TacticalGoldBrush}"/>
                        </StackPanel>

                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Content="Toggle Mode (Progress / Actuals)" 
                                Command="{Binding ToggleEditModeCommand}" 
                                Style="{StaticResource TacticalSecondaryButtonStyle}"/>
                    </Grid>

                    <!-- Row 1: Summary Warning -->
                    <Border Grid.Row="1" Background="#33FF9900" Padding="10" CornerRadius="4" Margin="0,0,0,10"
                            Visibility="{Binding SelectedItem.IsSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Summary Item: Graph is read-only (Calculated from children)." 
                                   Foreground="#FFFF9900" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Row 2: The Graph -->
                    <local:InteractiveManipulatorGraph Grid.Row="2" 
                                                       DataPoints="{Binding InteractiveDataPoints}" 
                                                       EditMode="{Binding CurrentEditMode}"
                                                       StatusDate="{Binding SimulatedDate}"
                                                       IsEnabled="{Binding SelectedItem.IsLeaf}"
                                                       MaxActualHours="200"
                                                       Margin="0,0,0,10"/>

                    <!-- Row 3: Actions -->
                    <Button Grid.Row="3" Content="Flatline Future (Drop last 3 weeks)" 
                            Command="{Binding FlatlineFutureCommand}" 
                            Style="{StaticResource TacticalWarningButtonStyle}" 
                            Width="250" HorizontalAlignment="Left"
                            Visibility="{Binding SelectedItem.IsLeaf, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- SECTION 2: CRITICAL PATH SHIFT ALERT -->
        <Border Grid.Row="2" Margin="0,5,0,0"
                Visibility="{Binding HasCriticalPathAlert, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#33FF4444" BorderBrush="#FF5555" BorderThickness="1" 
                    CornerRadius="6" Padding="12,8">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CriticalPathAlert}" 
                                   Foreground="#FF5555" FontWeight="Bold" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="CRITICAL PATH SHIFT DETECTED" 
                               HorizontalAlignment="Right"
                               Foreground="#FF5555" FontWeight="Bold" FontSize="11"
                               Opacity="0.6" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Border>

         <!-- SECTION 3: IMPACT METRICS DASHBOARD -->
        <Border Grid.Row="3" Background="{StaticResource TacticalDarkAccentBrush}" CornerRadius="6" Padding="12" Margin="0,5,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SV -->
                <StackPanel Grid.Column="0" Margin="5,0">
                    <TextBlock Text="SCHEDULE VARIANCE (SV)" Style="{StaticResource MetricCardHeaderStyle}"/>
                    <TextBlock Text="{Binding LiveTotalSv, StringFormat={}{0:C0}}" Style="{StaticResource MetricValueStyle}"/>
                    <TextBlock Text="{Binding SimTotalSv, StringFormat={}{0:C0}}" Style="{StaticResource MetricSimValueStyle}"/>
                    <TextBlock Text="{Binding ImpactSv, StringFormat='Δ {0:#,##0;(#,##0);0}'}" 
                               Foreground="{Binding ImpactSv, Converter={StaticResource EvmDeltaColorConverter}}"
                               Style="{StaticResource MetricDeltaStyle}"/>
                </StackPanel>

                <!-- CV -->
                <StackPanel Grid.Column="1" Margin="5,0">
                    <TextBlock Text="COST VARIANCE (CV)" Style="{StaticResource MetricCardHeaderStyle}"/>
                    <TextBlock Text="{Binding LiveTotalCv, StringFormat={}{0:C0}}" Style="{StaticResource MetricValueStyle}"/>
                    <TextBlock Text="{Binding SimTotalCv, StringFormat={}{0:C0}}" Style="{StaticResource MetricSimValueStyle}"/>
                    <TextBlock Text="{Binding ImpactCv, StringFormat='Δ {0:#,##0;(#,##0);0}'}" 
                               Foreground="{Binding ImpactCv, Converter={StaticResource EvmDeltaColorConverter}}"
                               Style="{StaticResource MetricDeltaStyle}"/>
                </StackPanel>

                <!-- SPI -->
                <StackPanel Grid.Column="2" Margin="5,0">
                    <TextBlock Text="SCHEDULE INDEX (SPI)" Style="{StaticResource MetricCardHeaderStyle}"/>
                    <TextBlock Text="{Binding LiveTotalSpi, StringFormat=N2}" Style="{StaticResource MetricValueStyle}"/>
                    <TextBlock Text="{Binding SimTotalSpi, StringFormat=N2}" Style="{StaticResource MetricSimValueStyle}"/>
                    <TextBlock Text="{Binding ImpactSpi, StringFormat='Δ {0:0.00}'}" 
                               Foreground="{Binding ImpactSpi, Converter={StaticResource EvmDeltaColorConverter}}"
                               Style="{StaticResource MetricDeltaStyle}"/>
                </StackPanel>

                <!-- CPI -->
                <StackPanel Grid.Column="3" Margin="5,0">
                    <TextBlock Text="COST INDEX (CPI)" Style="{StaticResource MetricCardHeaderStyle}"/>
                    <TextBlock Text="{Binding LiveTotalCpi, StringFormat=N2}" Style="{StaticResource MetricValueStyle}"/>
                    <TextBlock Text="{Binding SimTotalCpi, StringFormat=N2}" Style="{StaticResource MetricSimValueStyle}"/>
                    <TextBlock Text="{Binding ImpactCpi, StringFormat='Δ {0:0.00}'}" 
                               Foreground="{Binding ImpactCpi, Converter={StaticResource EvmDeltaColorConverter}}"
                               Style="{StaticResource MetricDeltaStyle}"/>
                </StackPanel>

                <!-- EAC -->
                <StackPanel Grid.Column="4" Margin="5,0">
                    <TextBlock Text="EST. AT COMPLETION (EAC)" Style="{StaticResource MetricCardHeaderStyle}"/>
                    <TextBlock Text="{Binding LiveTotalEac, StringFormat={}{0:C0}}" Style="{StaticResource MetricValueStyle}"/>
                    <TextBlock Text="{Binding SimTotalEac, StringFormat={}{0:C0}}" Style="{StaticResource MetricSimValueStyle}"/>
                    <TextBlock Text="{Binding ImpactEac, StringFormat='Δ {0:#,##0;(#,##0);0}'}" 
                               Foreground="{Binding ImpactEac, Converter={StaticResource EvmDeltaColorConverter}, ConverterParameter=Inverted}"
                               Style="{StaticResource MetricDeltaStyle}"/>
                </StackPanel>

                <!-- TCPI -->
                <StackPanel Grid.Column="5" Margin="5,0">
                    <TextBlock Text="TO-COMPLETE INDEX" Style="{StaticResource MetricCardHeaderStyle}"/>
                    <TextBlock Text="{Binding LiveTotalTcpi, StringFormat=N2}" Style="{StaticResource MetricValueStyle}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding SimTotalTcpi, StringFormat=N2}" Style="{StaticResource MetricSimValueStyle}"/>
                        <!-- Warning indicator if TCPI is high -->
                        <TextBlock Text=" ⚠" Foreground="#FF5555" FontWeight="Bold" Visibility="{Binding SimTotalTcpi, Converter={StaticResource EvmDeltaColorConverter}, ConverterParameter=HighTcpiWarning}"/>
                    </StackPanel>
                    <TextBlock Text="⚠ STEEP RECOVERY — Efficiency gain &gt;10% required" 
                               Foreground="#FF5555" FontSize="9" FontWeight="Bold" Margin="0,2,0,0"
                               Visibility="{Binding SimTotalTcpi, Converter={StaticResource EvmDeltaColorConverter}, ConverterParameter=HighTcpiWarning}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Critical Path Count Indicator -->
        <TextBlock Grid.Row="3" 
                   Text="{Binding CriticalPathCount, StringFormat='{}{0} task(s) on the critical path'}" 
                   Foreground="{StaticResource TacticalTextMutedBrush}" 
                   FontSize="10" Margin="17,0,0,0"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom"/>

        <!-- SECTION 4: SANDBOX GANTT -->
        <Border Grid.Row="4" Background="{StaticResource TacticalCardBrush}" CornerRadius="6" Padding="5">
            <gantt:GanttView DataContext="{Binding SandboxGanttContext}" />
        </Border>
    </Grid>
</UserControl>
