<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.Simulation.InteractiveManipulatorGraph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="GraphControl">
    <Grid Margin="10,20,10,10">
        <!-- Added top margin for 100% label -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Graph Area -->
            <RowDefinition Height="30"/>
            <!-- X-Axis Labels -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <!-- Y-Axis Labels -->
            <ColumnDefinition Width="*"/>
            <!-- Graph Area -->
        </Grid.ColumnDefinitions>

        <!-- Main Graph Area with ClipToBounds False to allow thumbs to breathe -->
        <Border Grid.Row="0" Grid.Column="1" 
                BorderBrush="{StaticResource TacticalSeparatorBrush}" 
                BorderThickness="1,0,0,1" 
                Margin="0,0,10,0">
            <Canvas x:Name="GraphCanvas" Background="#05FFFFFF" SizeChanged="GraphCanvas_SizeChanged"/>
        </Border>

        <Canvas x:Name="YAxisCanvas" Grid.Row="0" Grid.Column="0"/>
        <Canvas x:Name="XAxisCanvas" Grid.Row="1" Grid.Column="1"/>
    </Grid>
</UserControl>
