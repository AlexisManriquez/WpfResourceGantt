<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.Simulation.InteractiveManipulatorGraph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="GraphControl">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <!-- Top padding -->
            <RowDefinition Height="*"/>
            <!-- Graph Area -->
            <RowDefinition Height="30"/>
            <!-- X-Axis Labels -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <!-- Y-Axis Labels -->
                <ColumnDefinition Width="*"/>
                <!-- Graph Area -->
                <ColumnDefinition Width="20"/>
                <!-- Right padding -->
            </Grid.ColumnDefinitions>

            <!-- Y-Axis Label -->
        <Canvas x:Name="YAxisCanvas" Grid.Row="1" Grid.Column="0"/>

        <!-- The main drawing area -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{StaticResource TacticalSeparatorBrush}" BorderThickness="1,0,0,1" ClipToBounds="True">
            <Canvas x:Name="GraphCanvas" Background="Transparent" SizeChanged="GraphCanvas_SizeChanged"/>
        </Border>

        <!-- X-Axis Label -->
        <Canvas x:Name="XAxisCanvas" Grid.Row="2" Grid.Column="1"/>
    </Grid>
</UserControl>
