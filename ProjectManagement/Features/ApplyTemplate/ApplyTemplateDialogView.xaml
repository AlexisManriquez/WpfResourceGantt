<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.ApplyTemplate.ApplyTemplateDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfResourceGantt.ProjectManagement.Features.ApplyTemplate"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             Background="{StaticResource SurfaceBrush}"
             BorderBrush="{StaticResource TacticalGoldBrush}" BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Selection -->
            <RowDefinition Height="Auto"/>
            <!-- Options -->
            <RowDefinition Height="*"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Apply Project Template" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="{StaticResource TextPrimaryBrush}" 
                   Margin="0,0,0,20"/>

        <!-- Template Selection -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Select Template:" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding Templates}" 
                      SelectedItem="{Binding SelectedTemplate}"
                      DisplayMemberPath="Name"
                      Height="35" FontSize="14" Padding="5"/>
            <TextBlock Text="{Binding SelectedTemplate.Description}" 
                       Foreground="{StaticResource TacticalTextMutedBrush}" 
                       FontStyle="Italic" Margin="0,5,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Mode Selection -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="Application Mode:" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,0,10"/>

            <RadioButton GroupName="Mode" IsChecked="{Binding IsAppend}" 
                         Content="Append to existing items" 
                         Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,8"/>

            <RadioButton GroupName="Mode" IsChecked="{Binding IsOverwrite}" 
                         Content="Overwrite (Delete all existing children)" 
                         Foreground="{StaticResource StatusBusyBrush}" FontSize="14"/>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding CancelCommand}" 
                    Content="Cancel"
                    Background="Transparent" Foreground="{StaticResource TacticalTextMutedBrush}"
                    BorderThickness="0" Margin="0,0,10,0" Padding="10,5"/>

            <Button Command="{Binding ConfirmCommand}" 
                    Content="Apply Template"
                    Background="{StaticResource PrimaryActionBrush}" Foreground="{StaticResource TextInverseBrush}"
                    Padding="15,8">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
