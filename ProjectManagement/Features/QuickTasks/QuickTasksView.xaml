<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.QuickTasks.QuickTasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfResourceGantt.ProjectManagement.Features.QuickTasks"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance local:QuickTasksViewModel}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../UI/Styles/CoreStyles.xaml"/>
                <ResourceDictionary Source="../../UI/Styles/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <!-- Value Converter for Strikethrough -->
            <Style x:Key="TaskTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource TacticalTextPrimaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                        <Setter Property="Foreground" Value="{StaticResource TacticalTextMutedBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource TacticalBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Columns -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <!-- Header -->
        <Border Padding="20" BorderBrush="{StaticResource TacticalSeparatorBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Quick Tasks" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TacticalTextPrimaryBrush}"/>
                    <TextBlock Text="Assign and track quick assignments" FontSize="14" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- USER FILTER -->
                    <!-- USER FILTER -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,8,0"/>
                        <Grid>
                            <ComboBox ItemsSource="{Binding AllUsers}" 
                  SelectedItem="{Binding SelectedFilterUser, Mode=TwoWay}"
                  DisplayMemberPath="Name"
                  Width="180"
                  VerticalAlignment="Center">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{StaticResource TacticalRibbonBackgroundBrush}"/>
                                    </Style>
                                </ComboBox.Resources>
                            </ComboBox>

                            <!-- Placeholder Hint: Visible only when SelectedFilterUser is null -->
                            <TextBlock Text="All Personnel" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Left" 
                   Margin="10,0,0,0"
                   Foreground="{StaticResource TacticalTextMutedBrush}"
                   IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFilterUser}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Clear Filter Button -->
                        <!-- Consistent Clear Filter Button -->
                        <Button Command="{Binding ClearFilterCommand}" 
        ToolTip="Reset Filters"
        Margin="5,0,0,0">
                            <Button.Style>
                                <!-- Extending the ActionButtonStyle to include the Visibility Trigger -->
                                <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedFilterUser}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✕" 
                   Foreground="{StaticResource StatusBusyBrush}" 
                   FontSize="14" 
                   Margin="0,0,5,0" 
                   VerticalAlignment="Center"/>
                                <TextBlock Text="Clear" 
                   Foreground="{StaticResource TacticalTextMutedBrush}" 
                   FontSize="12" 
                   VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button Command="{Binding OpenAddTaskCommand}" Content="+ Assign Task" Style="{StaticResource TacticalPrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Kanban Board -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/> <!-- Pending -->
                <ColumnDefinition Width="20"/> <!-- Spacing -->
                <ColumnDefinition Width="*"/> <!-- Completed -->
            </Grid.ColumnDefinitions>

            <!-- PENDING COLUMN -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource TacticalGoldBrush}" BorderThickness="0,2,0,0" Padding="12" Background="#23282E" CornerRadius="4,4,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Clock}" Fill="{StaticResource TacticalGoldBrush}" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="PENDING" FontWeight="Bold" Foreground="{StaticResource TacticalTextPrimaryBrush}"/>
                        </StackPanel>
                        <Border Background="#3C4148" CornerRadius="10" HorizontalAlignment="Right" Padding="8,2">
                            <TextBlock Text="{Binding PendingTasks.Count}" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="12" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
                
                <Border Background="#15191D" CornerRadius="0,0,4,4" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <!-- Empty State -->
                            <TextBlock Text="No pending tasks" 
                                   Foreground="{StaticResource TacticalTextMutedBrush}" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PendingTasks.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ItemsControl ItemsSource="{Binding PendingTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Background="#23282E" CornerRadius="4" Padding="12" BorderThickness="1" BorderBrush="#3C4148">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Toggle Button -->
                                                <Button Grid.Column="0" 
                                                    Command="{Binding DataContext.ToggleTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Margin="0,0,12,0" VerticalAlignment="Top">
                                                    <Border Width="20" Height="20" CornerRadius="10" BorderBrush="{StaticResource TacticalTextMutedBrush}" BorderThickness="2"/>
                                                </Button>

                                                <!-- Content -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource TaskTitleStyle}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" MaxHeight="40"/>

                                                    <!-- Footer -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <!-- Use a Path for User Icon -->
                                                        <Image Source="{StaticResource Icon_Users}" Width="12" Height="12" Margin="0,0,4,0" Stretch="Uniform"/>
                                                        <TextBlock Text="{Binding AssignedUserName}" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="11" Margin="0,0,12,0"/>

                                                        <!-- Date Range -->
                                                        <Path Data="{StaticResource Icon_Calendar}" Fill="{StaticResource TacticalTextMutedBrush}" Width="12" Height="12" Margin="0,0,4,0" Stretch="Uniform"/>
                                                        <TextBlock Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="11">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:M/d} - {1:M/d}">
                                                                    <Binding Path="StartDate"/>
                                                                    <Binding Path="EndDate"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Actions (Visible on Hover via Trigger ideally, simpler here) -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                    <!-- EDIT BUTTON -->
                                                    <Button Command="{Binding DataContext.OpenEditTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
            CommandParameter="{Binding}"
            Background="Transparent" BorderThickness="0" Margin="0,0,8,0">
                                                        <Path Data="{StaticResource Icon_Edit}" Fill="{StaticResource TacticalTextMutedBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                                    </Button>

                                                    <!-- DELETE BUTTON (Existing) -->
                                                    <Button Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
            CommandParameter="{Binding}"
            Background="Transparent" BorderThickness="0">
                                                        <Path Data="{StaticResource Icon_Delete}" Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </DockPanel>

            <!-- COMPLETED COLUMN -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" BorderBrush="#10B981" BorderThickness="0,2,0,0" Padding="12" Background="#23282E" CornerRadius="4,4,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_CheckCircle}" Fill="#10B981" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"/>
                            <TextBlock Text="COMPLETED" FontWeight="Bold" Foreground="{StaticResource TacticalTextPrimaryBrush}"/>
                        </StackPanel>
                        <Border Background="#3C4148" CornerRadius="10" HorizontalAlignment="Right" Padding="8,2">
                            <TextBlock Text="{Binding CompletedTasks.Count}" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="12" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Background="#15191D" CornerRadius="0,0,4,4" Padding="8">
                    <ScrollViewer>
                        <Grid>
                            <!-- Empty State -->
                            <TextBlock Text="No completed tasks yet" 
                                   Foreground="{StaticResource TacticalTextMutedBrush}" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CompletedTasks.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ItemsControl ItemsSource="{Binding CompletedTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Background="#1F2937" CornerRadius="4" Padding="12" Opacity="0.7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Toggle Button (Checked) -->
                                                <Button Grid.Column="0" 
                                                    Command="{Binding DataContext.ToggleTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Margin="0,0,12,0" VerticalAlignment="Top">
                                                    <Path Data="{StaticResource Icon_CheckCircle}" Fill="#10B981" Width="20" Height="20" Stretch="Uniform"/>
                                                </Button>

                                                <!-- Content -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource TaskTitleStyle}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" MaxHeight="40"/>

                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <Image Source="{StaticResource Icon_Users}" Width="12" Height="12" Margin="0,0,4,0" Stretch="Uniform"/>
                                                        <TextBlock Text="{Binding AssignedUserName}" Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="11" Margin="0,0,12,0"/>

                                                        <!-- Date Range -->
                                                        <Path Data="{StaticResource Icon_Calendar}" Fill="{StaticResource TacticalTextMutedBrush}" Width="12" Height="12" Margin="0,0,4,0" Stretch="Uniform"/>
                                                        <TextBlock Foreground="{StaticResource TacticalTextMutedBrush}" FontSize="11">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:M/d} - {1:M/d}">
                                                                    <Binding Path="StartDate"/>
                                                                    <Binding Path="EndDate"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Actions -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                    <!-- EDIT BUTTON -->
                                                    <Button Command="{Binding DataContext.OpenEditTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
            CommandParameter="{Binding}"
            Background="Transparent" BorderThickness="0" Margin="0,0,8,0">
                                                        <Path Data="{StaticResource Icon_Edit}" Fill="{StaticResource TacticalTextMutedBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                                    </Button>

                                                    <!-- DELETE BUTTON (Existing) -->
                                                    <Button Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
            CommandParameter="{Binding}"
            Background="Transparent" BorderThickness="0">
                                                        <Path Data="{StaticResource Icon_Delete}" Fill="#EF4444" Width="14" Height="14" Stretch="Uniform"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </DockPanel>
        </Grid>

        <!-- CREATE TASK MODAL -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Background="#AA000000" Visibility="{Binding IsAddTaskModalOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#1F2937" Width="400" VerticalAlignment="Center" CornerRadius="8" Padding="24" BorderBrush="#374151" BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <!-- Update the Header Text inside the CREATE TASK MODAL -->
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="White">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Edit Quick Task"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NewTaskName}" Value="New Task">
                                            <Setter Property="Text" Value="Assign Quick Task"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding CancelAddTaskCommand}" Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#9CA3AF" FontWeight="Bold"/>
                    </Grid>
                    
                    <TextBlock Text="Create a quick task or assignment for a team member." Foreground="#9CA3AF" Margin="0,0,0,20"/>

                    <TextBlock Text="Task Title" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}" Background="#111827" BorderBrush="#374151" Foreground="White" Padding="8" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start Date" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding NewTaskStartDate}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="End Date" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding NewTaskEndDate}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Description (optional)" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewTaskDescription, UpdateSourceTrigger=PropertyChanged}" Background="#111827" BorderBrush="#374151" Foreground="White" Padding="8" Height="60" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Assigned To (Simplified: Just Current User implied or text for now, could be ComboBox later) -->
                    <TextBlock Text="Assigned To" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AllUsers}" 
                              SelectedItem="{Binding SelectedAssignee}"
                              DisplayMemberPath="Name"
                              Padding="8" Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelAddTaskCommand}" Content="Cancel" Background="Transparent" Foreground="White" BorderThickness="1" BorderBrush="#374151" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Command="{Binding SaveNewTaskCommand}" Content="Assign Task" Style="{StaticResource TacticalPrimaryButtonStyle}" Padding="12,6"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
