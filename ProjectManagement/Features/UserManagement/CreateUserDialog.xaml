<Window x:Class="WpfResourceGantt.ProjectManagement.Features.UserManagement.CreateUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfResourceGantt.ProjectManagement"
        mc:Ignorable="d"
        Title="Create New User" Height="450" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Style="{StaticResource TacticalWindowStyle}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <local:StringToIsNotEmptyConverter x:Key="StringToIsNotEmptyConverter"/>
    </Window.Resources>

    <!-- Main border for custom window chrome (rounded corners, shadow) -->
    <Border Background="{StaticResource AppBackgroundBrush}" 
            CornerRadius="12" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="Black" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <!-- Custom Close Button -->
            <Button VerticalAlignment="Top" HorizontalAlignment="Right" 
                    Style="{StaticResource BtnGhost}"
                    Content="✕" FontSize="16"
                    Margin="0,10,10,0" Click="CloseButton_Click"/>

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Form Fields -->
                    <RowDefinition Height="*"/>    <!-- Spacer -->
                    <RowDefinition Height="Auto"/> <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="Create New User" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TacticalGoldBrush}"/>
                    <TextBlock Text="Add a new team member with the appropriate role." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Form Fields -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Full Name" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBox x:Name="FullNameTextBox" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Section" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Section, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,0,15"/>

                    <TextBlock Text="Role" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AllRoles}" 
                              SelectedItem="{Binding SelectedRole}"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Cancel" 
                            Style="{StaticResource BtnOutline}" 
                            Width="100"
                            Margin="0,0,12,0" 
                            IsCancel="True" 
                            Click="CloseButton_Click"/>

                    <Button x:Name="CreateButton" 
                            Content="Create User" 
                            IsDefault="True" 
                            Width="120"
                            Click="CreateButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding FullName, Converter={StaticResource StringToIsNotEmptyConverter}}" Value="True"/>
                                            <Condition Binding="{Binding Section, Converter={StaticResource StringToIsNotEmptyConverter}}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="True"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
