<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.EVM.EVMView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:cv="clr-namespace:WpfResourceGantt.ProjectManagement.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800"
             Background="{StaticResource AppBackgroundBrush}">
    <UserControl.Resources>
        <cv:EnumToBooleanConverter x:Key="EnumToBoolConverter" />
        <cv:LevelToIndentConverter x:Key="IndentConverter" />
        <cv:EvmMetricMultiConverter x:Key="EvmMetricMultiConverter" />
        <!-- Shared Style for Filter ComboBoxes (Copied from GanttView for consistency) -->
        <DataTemplate x:Key="FilterDropdownItemTemplate">
            <TextBlock Text="{Binding Name}" Padding="5" Foreground="{StaticResource TextPrimaryBrush}"/>
        </DataTemplate>
        <Style x:Key="TacticalFilterComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          Background="{TemplateBinding Background}"
                                          Foreground="{TemplateBinding Foreground}"
                                          Grid.Column="2" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" Focusable="false" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                            <Path x:Name="Arrow" Fill="{StaticResource TacticalTextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Data="M 0 0 L 4 4 L 8 0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#3E3E42" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,30,3" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{StaticResource SurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource TacticalGoldBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AppBackgroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedToggleStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TacticalTextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource TacticalGoldBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AppBackgroundBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource TacticalGoldBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource TacticalGoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <!-- Single Column Layout -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- No Sidebar -->


        <!-- MAIN CONTENT: The S-Curve and Header -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
            <!-- THIS IS THE "OUTER MOST GRID" FOR THE DASHBOARD CONTENT -->
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Row 0: Zone A (Header) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 1: Zone B (KPI Cards) -->
                    <RowDefinition Height="25"/>
                    <!-- Row 2: Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 3: Zone C (S-Curve & Trend Charts) -->
                    <RowDefinition Height="25"/>
                    <!-- Row 4: Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 5: Zone D (WBS Detail Grid) -->
                </Grid.RowDefinitions>

                <!-- ZONE A: HEADER (Row 0) -->
                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="System: " VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding ProjectOptions}"
                                  SelectedItem="{Binding SelectedProjectFilter}"
                                  Style="{StaticResource TacticalFilterComboBox}"
                                  Width="250"
                                  Tag="Select Project..."/>
                                  
                        <TextBlock Text="{Binding ContextHeader}" 
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="Earned Value Performance Report" 
                               FontSize="14" Foreground="{StaticResource TacticalTextMutedBrush}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Zone B: KPI Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <!-- Spacer -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <!-- Spacer -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <!-- Spacer -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <!-- Spacer -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CARD 1: SCHEDULE HEALTH (SPI) -->
                    <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="5" 
            BorderBrush="{Binding SpiColor}" BorderThickness="0,4,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.1"/>
                        </Border.Effect>

                        <StackPanel Margin="15">
                            <!-- Header -->
                            <TextBlock Text="SCHEDULE HEALTH (SPI)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,0,10"/>

                            <!-- The Gauge -->
                            <lvc:AngularGauge Value="{Binding CurrentSPI}" Foreground="{StaticResource TextPrimaryBrush}"
                              FromValue="0" 
                              ToValue="2"
                              LabelsStep="0.5"
                              TicksStep="0.25"
                              Wedge="180" 
                              TicksForeground="White"
                              NeedleFill="{StaticResource TacticalGoldBrush}"
                              Height="120">
                                <lvc:AngularGauge.Sections>
                                    <!-- Red Zone (0.0 - 0.9) -->
                                    <lvc:AngularSection FromValue="0" ToValue="0.9" Fill="#FF4D4D"/>
                                    <!-- Yellow Zone (0.9 - 0.99) -->
                                    <lvc:AngularSection FromValue="0.9" ToValue="0.99" Fill="#FFC107"/>
                                    <!-- Green Zone (1.0 - 2.0) -->
                                    <lvc:AngularSection FromValue="0.99" ToValue="2" Fill="#00C853"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>

                            <!-- Value Text (Overlaying the gauge center usually requires a Grid, 
                 but placing it below is easier for now) -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,-30,0,10">
                                <TextBlock Text="{Binding CurrentSPI, StringFormat=N2}" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="{Binding SpiColor}" 
                           HorizontalAlignment="Center"/>
                                <TextBlock Text="BCWP / BCWS" FontSize="10" Foreground="{StaticResource TacticalTextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Separator Background="#EEEEEE" Margin="0,5"/>

                            <!-- Variance Subtext -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                <TextBlock Text="Schedule Variance: " FontSize="11" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                            <Binding Path="CurrentScheduleVariance" />
                                            <Binding Path="DisplayMode" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Placeholders for other cards -->
                    <!-- CARD 2: COST HEALTH (CPI) -->
                    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="5" 
        BorderBrush="{Binding CpiColor}" BorderThickness="0,4,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.1"/>
                        </Border.Effect>

                        <StackPanel Margin="15">
                            <!-- Header -->
                            <TextBlock Text="COST HEALTH (CPI)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,0,10"/>

                            <!-- The Gauge -->
                            <lvc:AngularGauge Value="{Binding CurrentCPI}" 
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FromValue="0" 
                          ToValue="2"
                          LabelsStep="0.5"
                          TicksStep="0.25"
                          Wedge="180" 
                          TicksForeground="White"
                          NeedleFill="{StaticResource TacticalGoldBrush}"
                          Height="120">
                                <lvc:AngularGauge.Sections>
                                    <!-- Red Zone (0.0 - 0.95) -->
                                    <lvc:AngularSection FromValue="0" ToValue="0.95" Fill="#FF4D4D"/>
                                    <!-- Yellow Warning Buffer (0.95 - 1.0) optional -->
                                    <lvc:AngularSection FromValue="0.95" ToValue="1.0" Fill="#FFC107"/>
                                    <!-- Green Zone (1.0 - 2.0) -->
                                    <lvc:AngularSection FromValue="1.0" ToValue="2.0" Fill="#00C853"/>
                                </lvc:AngularGauge.Sections>
                            </lvc:AngularGauge>

                            <!-- Value Text -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,-30,0,10">
                                <TextBlock Text="{Binding CurrentCPI, StringFormat=N2}" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="{Binding CpiColor}" 
                       HorizontalAlignment="Center"/>
                                <TextBlock Text="BCWP / ACWP" FontSize="10" Foreground="{StaticResource TacticalTextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Separator Background="#EEEEEE" Margin="0,5"/>

                            <!-- Variance Subtext -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                <TextBlock Text="Cost Variance: " FontSize="11" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                            <Binding Path="CurrentCostVariance" />
                                            <Binding Path="DisplayMode" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- CARD 3: PROGRESS -->
                    <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}" CornerRadius="5" 
        BorderBrush="{StaticResource StatusBusyBrush}" BorderThickness="0,4,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.1"/>
                        </Border.Effect>

                        <StackPanel Margin="15">
                            <!-- Header -->
                            <TextBlock Text="PROGRESS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,0,10"/>

                            <!-- Donut Chart Container -->
                            <Grid Height="120" Width="120">
                                <!-- The Chart -->
                                <lvc:PieChart Series="{Binding ProgressSeries}" InnerRadius="45" LegendLocation="None" Hoverable="False" DataTooltip="{x:Null}" DisableAnimations="True"></lvc:PieChart>
                                <!-- Center Text Overlay -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CurrentProgress, StringFormat=P0}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           HorizontalAlignment="Center"/>
                                    <TextBlock Text="Complete" 
                           FontSize="10" 
                           Foreground="{StaticResource TacticalTextMutedBrush}" 
                           HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#EEEEEE" Margin="0,5"/>

                            <!-- Footer Text -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                <TextBlock Text="Target Finish: " FontSize="11" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                                <TextBlock Text="{Binding TargetFinishDate, StringFormat=MMM dd yyyy}" 
                       FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- CARD 4: ESTIMATE AT COMPLETION -->
                    <Border Grid.Column="6" Background="{StaticResource SurfaceBrush}" CornerRadius="5" 
        BorderBrush="{StaticResource StatusAvailableBrush}" BorderThickness="0,4,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.1"/>
                        </Border.Effect>

                        <StackPanel Margin="15">
                            <TextBlock Text="ESTIMATE AT COMPLETION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,0,20"/>

                            <!-- The Big Number -->
                            <TextBlock FontSize="28" 
                    FontWeight="Bold" 
                    Foreground="{StaticResource StatusAvailableBrush}" 
                    HorizontalAlignment="Center"
                    Margin="0,10">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                        <Binding Path="EAC" />
                                        <Binding Path="DisplayMode" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- The Baseline Comparison -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="BAC: " FontSize="12" Foreground="{StaticResource TacticalTextMutedBrush}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextPrimaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                            <Binding Path="TotalBAC" />
                                            <Binding Path="DisplayMode" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <Separator Background="#EEEEEE" Margin="0,15,0,10"/>

                            <!-- The Variance -->
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Variance at Completion:" FontSize="10" Foreground="{StaticResource TacticalTextMutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock FontSize="14" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}" 
                       HorizontalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                            <Binding Path="VAC" />
                                            <Binding Path="DisplayMode" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <!-- CARD 5: TO COMPLETE PERFORMANCE INDEX -->
                    <Border Grid.Column="8" Background="{StaticResource SurfaceBrush}" CornerRadius="5" 
        BorderBrush="{Binding TcpiColor}" BorderThickness="0,4,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.1"/>
                        </Border.Effect>

                        <StackPanel Margin="15">
                            <TextBlock Text="TO COMPLETE PERFORMANCE INDEX" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,0,10"/>

                            <!-- The Big Number -->
                            <TextBlock Text="{Binding TCPI, StringFormat=N2}" 
                   FontSize="48" 
                   FontWeight="Bold" 
                   Foreground="{Binding TcpiColor}" 
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>

                            <!-- Status Text -->
                            <TextBlock Text="{Binding TcpiStatus}" 
                   FontSize="12" 
                   FontWeight="SemiBold"
                   Foreground="{Binding TcpiColor}" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

                            <Separator Background="#EEEEEE" Margin="0,5"/>

                            <!-- Footer Text -->
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Required efficiency: " FontSize="10" Foreground="{StaticResource TacticalTextMutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="to finish on budget" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Zone C-->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <!-- S-Curve (Wider) -->
                        <ColumnDefinition Width="20" />
                        <!-- Spacer -->
                        <ColumnDefinition Width="1*" />
                        <!-- Trend Chart (Narrower) -->
                    </Grid.ColumnDefinitions>
                    <!-- The Chart Container (Zone C) -->
                    <Border Grid.Column ="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Opacity="0.1"/>
                        </Border.Effect>

                        <Grid>
                            <!-- Inner Grid to arrange chart elements -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Chart Title -->
                                <RowDefinition Height="Auto"/>
                                <!-- Radio Buttons here -->
                                <RowDefinition Height="*"/>
                                <!-- The actual LiveCharts chart -->
                            </Grid.RowDefinitions>

                            <!-- Chart Header -->
                            <TextBlock Grid.Row="0" Text="Performance S-Curve" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               Margin="0,0,0,10"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,15">
                                <StackPanel.Resources>
                                    <!-- Style to make RadioButtons look like clickable toggle buttons -->
                                    <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                        <Setter Property="Padding" Value="12,6"/>
                                        <Setter Property="MinWidth" Value="80"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                </StackPanel.Resources>

                                <TextBlock Text="View Mode: " VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TacticalTextMutedBrush}"/>

                                <RadioButton Content="Hours" 
                                              Style="{StaticResource SegmentedToggleStyle}"
                 IsChecked="{Binding DisplayMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Hours}" />

                                <RadioButton Content="Cost ($)" 
                                              Style="{StaticResource SegmentedToggleStyle}"
                 IsChecked="{Binding DisplayMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Dollars}" />

                                <RadioButton Content="Progress (%)" 
                                              Style="{StaticResource SegmentedToggleStyle}"
                 IsChecked="{Binding DisplayMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Percent}" />
                            </StackPanel>


                            <!-- Existing Chart Code Here -->
                            <lvc:CartesianChart Grid.Row="2" 
                                    Series="{Binding ChartSeries}" 
                                    LegendLocation="Bottom"
                                    Zoom="None"
                                    Hoverable="False"
                                    Height="550" DisableAnimations="True">

                                <!-- X Axis (Time) -->
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Timeline" 
                                  Labels="{Binding ChartLabels}"
                                  Foreground="{StaticResource TacticalTextMutedBrush}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="{Binding LabelsStep}" StrokeThickness="0" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>

                                <!-- Y Axis (Hours/Cost) -->
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="{Binding YAxisTitle}"  
                                  LabelFormatter="{Binding YAxisFormatter}"
                                  MinValue="0"
                                  Foreground="{StaticResource TacticalTextMutedBrush}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="{StaticResource DividerBrush}" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>

                                <!-- Tooltip disabled for static view -->
                                <lvc:CartesianChart.DataTooltip>
                                    <x:Null/>
                                </lvc:CartesianChart.DataTooltip>

                            </lvc:CartesianChart>
                        </Grid>
                    </Border>
                    
                    <!-- CHART 2: PERFORMANCE INDEX TREND (New) -->
    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Opacity="0.1"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Chart Header -->
            <TextBlock Grid.Row="0" Text="Performance Index Trend" 
                       FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

            <!-- The Trend Chart -->
            <lvc:CartesianChart Grid.Row="1" 
                                Series="{Binding TrendSeries}" 
                                LegendLocation="Bottom" 
                                Zoom="None"
                                Hoverable="False"
                                Height="550" DisableAnimations="True">
                
                <!-- X Axis (Shared Labels) -->
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="Timeline" Labels="{Binding ChartLabels}" Foreground="{StaticResource TacticalTextMutedBrush}">
                        <lvc:Axis.Separator>
                            <!-- Hide vertical lines to make it cleaner -->
                            <lvc:Separator Step="{Binding LabelsStep}" StrokeThickness="0" />
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisX>

                <!-- Y Axis (Index) -->
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Index Value" LabelFormatter="{Binding IndexFormatter}" 
          MaxValue="2.0" 
          MinValue="0" Foreground="{StaticResource TacticalTextMutedBrush}">

                                        <!-- Add Reference Lines (Thresholds) -->
                                        <lvc:Axis.Sections>
                                            <!-- Green Line at 1.0 (Target) -->
                                            <!-- StrokeDashArray="4 2" means: 4 pixels dash, 2 pixels gap -->
                                            <lvc:AxisSection Value="1.0" 
                             Stroke="#00C853" 
                             StrokeThickness="2" 
                             StrokeDashArray="4 2"/>

                                            <!-- Yellow Line at 0.9 (Warning) -->
                                            <lvc:AxisSection Value="0.9" 
                             Stroke="#FFC107" 
                             StrokeThickness="1" 
                             StrokeDashArray="4 2"/>
                                        </lvc:Axis.Sections>

                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#E5E5E5" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>

                <lvc:CartesianChart.DataTooltip>
                    <x:Null/>
                </lvc:CartesianChart.DataTooltip>
            </lvc:CartesianChart>
        </Grid>
    </Border>
                </Grid>

                <!-- ZONE D: WBS DETAIL GRID -->
                <Border Grid.Row="5" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="0" Margin="0,25,0,0">


                    <ListView ItemsSource="{Binding FlatWbsItems}" 
                              SelectedItem="{Binding SelectedWbsItem, Mode=TwoWay}"
                              BorderThickness="0" 
                              Background="Transparent"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListView.Resources>
                            <!-- Header Style -->
                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TacticalTextMutedBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
                            </Style>
                        </ListView.Resources>

                        <ListView.View>
                            <GridView>
                                <!-- Column 0: WBS Name (Indented) -->
                                <GridViewColumn Header="WBS Name / ID" Width="350">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- This Margin is the only thing that moves -->
                                            <StackPanel Orientation="Horizontal" Margin="{Binding Level, Converter={StaticResource IndentConverter}}">
                                            <Button Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" 
                                                    BorderThickness="0" 
                                                    Margin="0,0,5,0"
                                                    Padding="0"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid Background="Transparent">
                                                            <TextBlock x:Name="Arrow" Text="? " Foreground="{StaticResource TacticalGoldBrush}" FontSize="10" VerticalAlignment="Center" Margin="2"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter TargetName="Arrow" Property="Text" Value="? "/>
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                                <TextBlock Text="{Binding WbsValue}" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 1: Start -->
                                <GridViewColumn Header="Start" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StartDate, StringFormat=yyyy-MM-dd}" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 2: Finish -->
                                <GridViewColumn Header="Finish" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding EndDate, StringFormat=yyyy-MM-dd}"/>
                                                <TextBlock Text="{Binding ActualFinishDate, StringFormat=({0:yyyy-MM-dd})}" Foreground="{StaticResource StatusUnassignedBrush}" FontSize="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Column 3: % Complete -->
                                <GridViewColumn Header="% Complete" Width="85">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Progress, StringFormat=P1}" HorizontalAlignment="Right" Width="60"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- EVM Columns (BAC, BCWS, BCWP, ACWP) -->
                                <GridViewColumn Header="BAC" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontWeight="Bold" HorizontalAlignment="Right" Width="80">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                                        <Binding Path="BAC" />
                                                        <Binding Path="DataContext.DisplayMode" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="BCWS" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Right" Width="80">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                                        <Binding Path="Bcws" />
                                                        <Binding Path="DataContext.DisplayMode" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="BCWP" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Right" Width="80">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                                        <Binding Path="Bcwp" />
                                                        <Binding Path="DataContext.DisplayMode" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="ACWP" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Right" Width="80">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource EvmMetricMultiConverter}">
                                                        <Binding Path="Acwp" />
                                                        <Binding Path="DataContext.DisplayMode" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- SPI Column -->
                                <GridViewColumn Header="SPI" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Width="60">
                                                <Ellipse Width="6" Height="6" Fill="{Binding SpiColor}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding CurrentSpi, StringFormat=N2}" Foreground="{Binding SpiColor}" FontWeight="Bold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- CPI Column -->
                                <GridViewColumn Header="CPI" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Width="60">
                                                <Ellipse Width="6" Height="6" Fill="{Binding CpiColor}" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding CurrentCpi, StringFormat=N2}" Foreground="{Binding CpiColor}" FontWeight="Bold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>




