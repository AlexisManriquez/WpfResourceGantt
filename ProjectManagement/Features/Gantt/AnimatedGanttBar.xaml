<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.Gantt.AnimatedGanttBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfResourceGantt.ProjectManagement"
             xmlns:gantt="clr-namespace:WpfResourceGantt.ProjectManagement.Features.Gantt"
             mc:Ignorable="d"  
             d:DesignHeight="40" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Main Content (Bars) -->
            <RowDefinition Height="Auto"/> <!-- Baseline Bar -->
        </Grid.RowDefinitions>

        <!-- 
            ===================================================================
            GROUP 1: Normal Task Bar
            ===================================================================
        -->
        <Grid x:Name="TaskBarGrid" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSummary, RelativeSource={RelativeSource AncestorType=gantt:AnimatedGanttBar}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border x:Name="CriticalPathBorder" 
                    BorderThickness="2" 
                    CornerRadius="5" 
                    Height="24" 
                    Margin="-2,0,-2,0"
                    Visibility="Collapsed" 
                    Panel.ZIndex="10"
                    IsHitTestVisible="False"/>
            <!-- 
                Duration Bar (The "Wiggle Room" visual)
                Blue = Good (plenty of float)
                Amber = Warning (TotalFloat 1–5 days)
                Red = Bad / Critical (TotalFloat ≤ 0)
            -->
            <Border CornerRadius="4" Height="18" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#DBEAFE"/> <!-- Light Blue-100 (Good) -->
                        <Setter Property="BorderBrush" Value="#3B82F6"/> <!-- Blue-500 -->
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <!-- Near-Critical: Yellow Warning Light -->
                            <DataTrigger Binding="{Binding ScheduleHealth, RelativeSource={RelativeSource AncestorType=gantt:AnimatedGanttBar}}" Value="Warning">
                                <Setter Property="Background" Value="#FEF3C7"/> <!-- Amber-100 -->
                                <Setter Property="BorderBrush" Value="#F59E0B"/> <!-- Amber-500 -->
                            </DataTrigger>
                            <!-- Critical Path: Red -->
                            <DataTrigger Binding="{Binding ScheduleHealth, RelativeSource={RelativeSource AncestorType=gantt:AnimatedGanttBar}}" Value="Bad">
                                <Setter Property="Background" Value="#FEE2E2"/> <!-- Light Red-100 -->
                                <Setter Property="BorderBrush" Value="#EF4444"/> <!-- Red-500 -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
            
            <!-- Progress Fill (Solid Color) -->
            <Border x:Name="TaskProgressBar" CornerRadius="3" Height="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#2563EB"/> <!-- Blue-600 (Good) -->
                        <Style.Triggers>
                            <!-- Near-Critical: Amber fill -->
                            <DataTrigger Binding="{Binding ScheduleHealth, RelativeSource={RelativeSource AncestorType=gantt:AnimatedGanttBar}}" Value="Warning">
                                <Setter Property="Background" Value="#D97706"/> <!-- Amber-600 -->
                            </DataTrigger>
                            <!-- Critical Path: Red fill -->
                            <DataTrigger Binding="{Binding ScheduleHealth, RelativeSource={RelativeSource AncestorType=gantt:AnimatedGanttBar}}" Value="Bad">
                                <Setter Property="Background" Value="#DC2626"/> <!-- Red-600 -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
        </Grid>

        <!-- 
            ===================================================================
            GROUP 2: Composite Summary Bar
            ===================================================================
        -->
        <Grid x:Name="SummaryBarGrid" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSummary, RelativeSource={RelativeSource AncestorType=gantt:AnimatedGanttBar}}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Bar -->
                <RowDefinition Height="Auto"/> <!-- Staple -->
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <!-- Health-Colored Background -->
                <Border x:Name="SummaryHealthBackground" CornerRadius="4" Height="20"/>
                <!-- Progress Fill -->
                <Border x:Name="SummaryProgressFill" CornerRadius="4" Height="20" HorizontalAlignment="Left" />
                <!-- Labels -->
                <TextBlock Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0" IsHitTestVisible="False" FontSize="10">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0:P0} | SV: {1:P0} | CV: {2:P0}">
                            <Binding Path="Progress" />
                            <Binding Path="DataContext.ScheduleVariancePercent" RelativeSource="{RelativeSource AncestorType=gantt:AnimatedGanttBar}" />
                            <Binding Path="DataContext.CostVariancePercent" RelativeSource="{RelativeSource AncestorType=gantt:AnimatedGanttBar}" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>

            <!-- Staple -->
            <Grid Grid.Row="1" Margin="0,1,0,0">
                <Rectangle Fill="#343A40" Height="2" VerticalAlignment="Top"/>
                <Rectangle Fill="#343A40" Width="2" Height="6" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Rectangle Fill="#343A40" Width="2" Height="6" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>
        </Grid>

        <!-- 
            ===================================================================
            GROUP 3: Baseline Bar (The "Ghost" Bar)
            ===================================================================
        -->
        <Border x:Name="BaselineBar" Grid.Row="1" Height="4" Background="#8094A3B8" CornerRadius="2" 
                HorizontalAlignment="Left" Margin="0,2,0,0"
                Visibility="{Binding IsBaselined, RelativeSource={RelativeSource AncestorType=gantt:AnimatedGanttBar}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>
