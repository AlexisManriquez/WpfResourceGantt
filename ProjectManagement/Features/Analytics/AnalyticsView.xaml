<UserControl x:Class="WpfResourceGantt.ProjectManagement.Features.Analytics.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:converters="clr-namespace:WpfResourceGantt.ProjectManagement.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
             
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Top Section (Cards + Pie) -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Bottom Section (Line Chart) -->
        </Grid.RowDefinitions>

        <!-- 1. HEADER (Title + Controls) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Future Availability Forecast" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Schedule Planning" FontSize="12" Foreground="{StaticResource TacticalTextMutedBrush}" Margin="0,5,0,0"/>
                </StackPanel>
                
                 <!-- Filter Controls for Analytics -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Role:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding AnalyticsRoleOptions}" SelectedItem="{Binding SelectedRoleFilter}" Width="150" Margin="0,0,15,0"/>

                     <TextBlock Text="Section:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding PieSectionOptions}" SelectedItem="{Binding SelectedSectionFilter}" Width="150" Margin="0,0,15,0"/>

                </StackPanel>
            </Grid>
        </StackPanel>


        <!-- 2. TOP SECTION (Cards + Pie) -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Left: Cards -->
                <ColumnDefinition Width="*"/>
                <!-- Right: Pie Chart -->
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: VERTICAL KPI CARDS -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0" Width="220">

                <!-- CARD 1: UNASSIGNED -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="⚠" Foreground="{StaticResource StatusUnassignedBrush}" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Unassigned" Foreground="{StaticResource TacticalTextMutedBrush}" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatUnassignedCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Backlog tasks" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- CARD 2: AVAILABLE TODAY -->
                <Border Background="{StaticResource SurfaceBrush}" 
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="1,1,1,1" 
                        CornerRadius="4" Padding="15" Margin="0,0,0,10">
                    <Grid>
                        <!-- The Left Status Accent Bar -->
                        <Border HorizontalAlignment="Left" Width="4" Background="{StaticResource StatusAvailableBrush}" 
                                CornerRadius="2,0,0,2" Margin="-15,-15,0,-15"/>

                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="{Binding KpiAvailableTitle}" FontSize="11" FontWeight="Bold" 
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding StatAvailableTodayCount}" FontSize="28" FontWeight="Bold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,5"/>
                            <TextBlock Text="Qualified Personnel" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CARD 3: TOTAL STAFF -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="👥" Foreground="{StaticResource StatusAssistingBrush}" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Total Resources" Foreground="{StaticResource TacticalTextMutedBrush}" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatTotalRelevantStaff}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="In selected role" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- RIGHT COLUMN: PIE CHART -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Height="320" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <!-- Col 0: Controls (Left) -->
                        <ColumnDefinition Width="*"/>
                        <!-- Col 1: Pie Chart (Center) -->
                        <ColumnDefinition Width="220"/>
                        <!-- Col 2: List (Right) -->
                    </Grid.ColumnDefinitions>

                    <!-- COLUMN 0: CONTROLS & LEGEND -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">

                        <!-- Title -->
                        <TextBlock Text="{Binding PieChartTitle}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" TextWrapping="Wrap"/>
                        

                        <!-- Custom Legend (Under Slider) -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StatusBusyBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="Busy" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Available Item (Emerald) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StatusAvailableBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="Available" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- COLUMN 1: PIE CHART (CENTER) -->
                    <!-- LegendLocation="None" because we built a custom one on the left -->
                    <Grid Grid.Column="1" Margin="10,0">
                        <lvc:PieChart Series="{Binding PieChartSeries}" 
                                      LegendLocation="None" 
                                      Hoverable="True" 
                                      InnerRadius="60"
                                      DisableAnimations="True">
                        </lvc:PieChart>
                    </Grid>

                    <!-- COLUMN 2: AVAILABLE LIST (RIGHT) -->
                    <Border Grid.Column="2" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="4" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="10,8" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                                <TextBlock Text="Available Resources" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>

                            <!-- Scrollable List -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding PieAvailablePeople}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1" Padding="10,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="•" Foreground="#22C55E" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <!-- Simple Role Text -->
                                                    <TextBlock Grid.Column="1" Text="{Binding Role}" FontSize="10" Foreground="{StaticResource TacticalTextMutedBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                </Grid>
            </Border>
        </Grid>

        <!-- 3. BOTTOM SECTION: LINE CHART -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Dynamic Title -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding LineChartTitle}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- RIGHT: Custom Legend -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,0">

                        <!-- Legend Item 1: Supply (Emerald Dot) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,25,0" VerticalAlignment="Center">
                            <Grid Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border Width="18" Height="2" Background="{StaticResource StatusAvailableBrush}" Opacity="0.5"/>
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StatusAvailableBrush}" HorizontalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Available People" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Legend Item 2: Demand (Amber Square) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border Width="18" Height="2" Background="{StaticResource StatusUnassignedBrush}" Opacity="0.5"/>
                                <!-- We use a Rectangle/Square for Demand to differentiate shape from Supply -->
                                <Rectangle Width="8" Height="8" Fill="{StaticResource StatusUnassignedBrush}" HorizontalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Unassigned Tasks" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <!-- LIVECHART -->
                <lvc:CartesianChart Grid.Row="1" Series="{Binding AvailabilitySeries}" LegendLocation="None" DisableAnimations="True">
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Resources" Foreground="{StaticResource TextSecondaryBrush}" 
                                  LabelFormatter="{Binding YFormatter}" 
                                  MinValue="0" 
                                  MaxValue="{Binding MaxYAxis}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="{StaticResource DividerBrush}" />
                            </lvc:Axis.Separator>
                            <lvc:Axis.Sections>
                                <!-- The Reference Line (Total Staff) -->
                                <!-- We calculate Total Staff dynamically in code, but visualized here -->
                                <lvc:AxisSection Value="{Binding FilteredTotalStaffCount}" 
                                                 StrokeThickness="1" 
                                                 Stroke="#16A34A" 
                                                 StrokeDashArray="5"
                                                 Label="Max Resources"/>
                            </lvc:Axis.Sections>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Labels="{Binding ChartLabels}" LabelsRotation="-45" Foreground="{StaticResource TextSecondaryBrush}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Step="{Binding AxisStep}" StrokeThickness="0" />
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>

                    <!-- Tooltip Style -->
                    <lvc:CartesianChart.DataTooltip>
                        <lvc:DefaultTooltip SelectionMode="OnlySender" Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}" BulletSize="10"/>
                    </lvc:CartesianChart.DataTooltip>
                </lvc:CartesianChart>
            </Grid>
        </Border>

    </Grid>
</UserControl>
