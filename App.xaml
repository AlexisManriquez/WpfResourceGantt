<Application x:Class="WpfResourceGantt.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfResourceGantt"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:conv="clr-namespace:WpfResourceGantt.ProjectManagement.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ProjectManagement/Themes/ProjectManagementResources.xaml"/>
                <ResourceDictionary Source="ProjectManagement/UI/Styles/Icons.xaml"/>
                <ResourceDictionary Source="ProjectManagement/UI/Styles/CoreStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ========================================================= -->
            <!-- 1. THEME PALETTE (Tactical / Dark Professional)          -->
            <!-- ========================================================= -->

            <!-- UI STRUCTURE -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E2329"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#23282E"/>
            <SolidColorBrush x:Key="SurfaceLightBrush" Color="#2D3238"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#3C4148"/>
            <SolidColorBrush x:Key="DividerBrush" Color="#2D3238"/>

            <!-- TEXT COLORS -->
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FAFAFA"/>
            <SolidColorBrush x:Key="TextBodyBrush" Color="#E0E2E5"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A1A6AD"/>
            <SolidColorBrush x:Key="TextInverseBrush" Color="#1E2329"/> <!-- Dark text on Gold -->

            <!-- BRANDING / INTERACTION -->
            <SolidColorBrush x:Key="PrimaryActionBrush" Color="#C5A065"/>
            <SolidColorBrush x:Key="PrimaryActionHoverBrush" Color="#D4AF76"/>
            <SolidColorBrush x:Key="PrimaryActionPressedBrush" Color="#A68550"/>

            <!-- STATUS COLORS -->
            <SolidColorBrush x:Key="StatusSuccessBrush" Color="#10B981"/>
            <SolidColorBrush x:Key="StatusWarningBrush" Color="#F59E0B"/>
            <SolidColorBrush x:Key="StatusDangerBrush" Color="#EF4444"/>
            <SolidColorBrush x:Key="StatusInfoBrush" Color="#3B82F6"/>

            <SolidColorBrush x:Key="StatusAvailableBrush" Color="#10B981"/>
            <SolidColorBrush x:Key="StatusAvailableLightBrush" Color="#10B981" Opacity="0.2"/>
            <SolidColorBrush x:Key="StatusBusyBrush" Color="#3B82F6"/>
            <SolidColorBrush x:Key="StatusBusyLightBrush" Color="#3B82F6" Opacity="0.2"/>
            <SolidColorBrush x:Key="StatusAssistingBrush" Color="#F59E0B"/>
            <SolidColorBrush x:Key="StatusAssistingLightBrush" Color="#F59E0B" Opacity="0.2"/>
            <SolidColorBrush x:Key="StatusOnHoldBrush" Color="#EF4444"/>
            <SolidColorBrush x:Key="StatusOnHoldLightBrush" Color="#EF4444" Opacity="0.2"/>
            <SolidColorBrush x:Key="StatusUnassignedBrush" Color="#A1A6AD"/>
            <SolidColorBrush x:Key="StatusUnassignedLightBrush" Color="#A1A6AD" Opacity="0.2"/>
            <!-- ========================================================= -->
            <!-- 2. GLOBAL BASE STYLES                                     -->
            <!-- ========================================================= -->

            <!-- DEFAULT TEXTBLOCK STYLE -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextBodyBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- DEFAULT WINDOW STYLE (TACTICAL DARK) -->
            <Style x:Key="TacticalWindowStyle" TargetType="Window">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>


            <!-- ========================================================= -->
            <!-- 3. DIMENSIONS & SHAPES                                    -->
            <!-- ========================================================= -->

            <sys:Double x:Key="InputHeight">34</sys:Double>


            <!-- ========================================================= -->
            <!-- 4. GLOBAL CONVERTERS                                      -->
            <!-- ========================================================= -->
            <conv:StatusToOpacityConverter x:Key="StatusToOpacityConverter"/>
            <conv:TaskStatusToBooleanConverter x:Key="StatusToBoolConverter"/>
            <conv:WorkItemStateConverter x:Key="WorkItemStateConverter"/>
            <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
            <conv:StringEqualityToVisibilityConverter x:Key="StringEqualityToVisibilityConverter"/>
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <!-- ========================================================= -->
            <!-- 5. CONTROL STYLES (Default Overrides in CoreStyles.xaml)  -->
            <!-- ========================================================= -->
            
            <!-- We keep these if they provide specific functional logic, but update colors -->
            <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource PrimaryActionBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextInverseBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="BtnOutline" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,0"/>
            </Style>
            
            <!-- COMBOBOX -->
            <!-- COMBOBOX STYLE (Fixed Compatibility) -->
            <!-- COMBOBOX (Professional DoD Style - Supports Grouping and DisplayMemberPath) -->
            <Style TargetType="ComboBox">
                <Setter Property="Height" Value="{StaticResource InputHeight}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                                <!-- 1. THE TOGGLE BUTTON (Handles the click to open) -->
                                <!-- We use a ToggleButton that spans the whole area -->
                                <ToggleButton x:Name="ToggleButton" 
                                  BorderBrush="{TemplateBinding BorderBrush}" 
                                  BorderThickness="{TemplateBinding BorderThickness}" 
                                  Background="{TemplateBinding Background}" 
                                  Grid.ColumnSpan="2" 
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="templateBorder" 
                                        Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                        CornerRadius="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Arrow Icon -->
                                                    <TextBlock Grid.Column="1" Text="▼" FontSize="8" 
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter TargetName="templateBorder" Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="true">
                                                    <Setter TargetName="templateBorder" Property="BorderBrush" Value="{StaticResource PrimaryActionBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- 2. THE SELECTED CONTENT DISPLAY -->
                                <ContentPresenter x:Name="ContentSite" 
                                      IsHitTestVisible="False" 
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                      Margin="10,0,35,0"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>

                                <!-- 3. THE DROPDOWN POPUP -->
                                <Popup x:Name="PART_Popup" 
                           AllowsTransparency="True" 
                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                           Placement="Bottom" 
                           PopupAnimation="Slide">
                                    <Border x:Name="DropDownBorder" 
                                Background="{StaticResource SurfaceBrush}" 
                                BorderBrush="{StaticResource BorderBrush}" 
                                BorderThickness="1" 
                                MinWidth="{Binding ActualWidth, ElementName=MainGrid}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.1"/>
                                        </Border.Effect>

                                        <!-- CRITICAL: ItemsPresenter is required to show GroupStyle -->
                                        <ScrollViewer x:Name="DropDownScrollViewer" Margin="0,2" CanContentScroll="False">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- COMBOBOX ITEM STYLE (Ensures the list items look clean) -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="gd" Background="Transparent" BorderThickness="0">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="gd" Property="Background" Value="{StaticResource StatusBusyLightBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryActionBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="gd" Property="Background" Value="{StaticResource PrimaryActionBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextInverseBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- DATEPICKER -->
            <Style TargetType="DatePicker">
                <Style.Resources>
                    <Style TargetType="DatePickerTextBox">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DatePickerTextBox">
                                    <Grid>
                                        <TextBox x:Name="PART_TextBox"
                                                 Text="{Binding Path=Text, RelativeSource={RelativeSource AncestorType={x:Type DatePicker}}}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="5,0"
                                                 VerticalContentAlignment="Center"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 CaretBrush="{StaticResource TacticalGoldBrush}"/>
                                        <TextBlock x:Name="Watermark"
                                                   Text="Select Date..."
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"
                                                   Visibility="Collapsed"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Style.Resources>
                <Setter Property="Height" Value="{StaticResource InputHeight}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Background" Value="#15191D"/>
                <Setter Property="Padding" Value="5,0"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DatePicker">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                                <Grid x:Name="PART_Root" Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Focusable="{TemplateBinding Focusable}"/>
                                    <Button x:Name="PART_Button" Grid.Column="1" Style="{StaticResource {ComponentResourceKey TypeInTargetAssembly={x:Type DatePicker}, ResourceId=DatePickerButtonStyle}}"/>
                                    <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" StaysOpen="False"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TacticalGoldBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- CHIP BUTTON STYLE (Professional / DoD Style) -->
            <Style x:Key="ChipButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Height" Value="28"/>
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{StaticResource TextBodyBrush}"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="FontSize" Value="11"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="4">
                                <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Hover Effect -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <!-- ACTIVE SELECTION (Navy Fill / White Text) -->
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="{StaticResource PrimaryActionBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextInverseBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- SIDEBAR NAVIGATION BUTTON STYLE -->
            <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <!-- Main container for the button state -->
                            <Border x:Name="ActiveIndicator" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="4" 
                        Margin="10,0">

                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <!-- Fixed width for icons -->
                                        <ColumnDefinition Width="12"/>
                                        <!-- Spacer -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Text Area -->
                                    </Grid.ColumnDefinitions>

                                    <!-- ICON AREA (Centered vertically) -->
                                    <ContentPresenter Grid.Column="0" 
                                          Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}" 
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Center"/>

                                    <!-- TEXT AREA -->
                                    <ContentPresenter Grid.Column="2" 
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ActiveIndicator" Property="Background" Value="{StaticResource PrimaryActionHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- CHOPPED: LIVECHARTS THEMING -->
            <Style TargetType="lvc:DefaultLegend">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Style>

            <Style TargetType="lvc:DefaultTooltip">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="Padding" Value="10" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
